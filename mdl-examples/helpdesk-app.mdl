-- ============================================================================
-- HelpDesk + KnowledgeBase — Full-Stack Application Baseline
-- ============================================================================
--
-- Purpose : End-to-end regression baseline (mx check must produce 0 new errors)
-- Modules : KB, HD
-- Version : Mendix 11.6+ (workflow requires 11.0+)
-- Design  : docs/superpowers/specs/2026-05-22-helpdesk-app-design.md
-- Facts   : docs/mendix-platform-reference.md
--
-- Edge cases covered:
--   Domain    : self-ref association, cross-module association,
--               non-persistent entity, many-to-many via junction table
--   Microflow : 5-state status machine, rollback branch, time comparison,
--               constant reference (@Module.Const),
--               retrieve with XPath + sort (XpathConstraint + NewSortings BSON),
--               retrieve with pagination (offset + limit expressions)
--   Nanoflow  : DB retrieve, call microflow, create+commit persistent,
--               pure-compute return value
--   Workflow  : parent-child, user task, multi-user task, decision (enum),
--               parallel split, jump, wait-for-notification,
--               interrupting + non-interrupting boundary events, annotation
--   Microflow workflow activities: all 13 (Call, ChangeState, CompleteTask,
--               ApplyJumpTo, GenerateJumpTo, RetrieveActivityRecords,
--               RetrieveContext, RetrieveWorkflows, ShowTaskPage,
--               ShowAdminPage, Lock, Unlock, Notify)
--   Security  : XPath row-level filters, module/user role mapping,
--               page/microflow grants, demo users
--   Navigation: role-derived menu visibility (no roles() on menu items)
--   ValidationFeedback: multi-field accumulate pattern, single-field bail-early pattern
--   Widget CE0463: known for dgTickets (DataGrid2 + ActionButton in custom column)
--                  and fStatus (DropdownFilter linked to dgTickets datasource);
--                  Studio Pro validates against internal platform definition,
--                  not the project MPK — exact comparison mechanism TBD.
--
-- Validation:
--   ./bin/mxcli check mdl-examples/use-cases/helpdesk/helpdesk-app.mdl
--
-- ============================================================================

-- MARK: KnowledgeBase — Module & Enumerations

create module KB;

create or modify enumeration KB.ArticleStatus (
  Draft      'Draft',
  Published  'Published',
  Archived   'Archived'
);



create or modify persistent entity KB.Category (
  Name:        string(200) not null,
  Description: string(500)
);

-- Self-referencing association: Category tree (parent → child)
create or modify association KB.Category_Parent
  from KB.Category to KB.Category
  type reference
  owner default;

create or modify persistent entity KB.Tag (
  Name: string(100) not null unique
);

create or modify persistent entity KB.Article (
  Title:       string(500) not null,
  Content:     string,
  Status:      KB.ArticleStatus default Draft,
  PublishedAt: datetime,
  ViewCount:   integer default 0
)
index (Status)
index (PublishedAt);

create or modify association KB.Article_Category
  from KB.Article to KB.Category
  type reference
  owner default;

-- Many-to-many junction table: Article <-> Tag
create or modify persistent entity KB.ArticleTag (
);

create or modify association KB.ArticleTag_Article
  from KB.ArticleTag to KB.Article
  type reference
  owner default;

create or modify association KB.ArticleTag_Tag
  from KB.ArticleTag to KB.Tag
  type reference
  owner default;

-- XPath row-level filter target: user sees only own ratings
create or modify persistent entity KB.ArticleRating (
  Score:   integer not null,
  Comment: string(1000)
)
system members (owner);

create or modify association KB.ArticleRating_Article
  from KB.ArticleRating to KB.Article
  type reference
  owner default;

-- MARK: HelpDesk — Module & Enumerations

create module HD;

-- 5-state status machine — edge case: Reopen (state reversal)
create or modify enumeration HD.TicketStatus (
  Draft      'Draft',
  Open       'Open',
  InProgress 'In Progress',
  Resolved   'Resolved',
  Closed     'Closed'
);

create or modify enumeration HD.TicketPriority (
  Low      'Low',
  Normal   'Normal',
  High     'High',
  Critical 'Critical'
);

-- MARK: HelpDesk — Entities & Non-persistent

create or modify persistent entity HD.Customer (
  Name:    string(200) not null,
  Email:   string(200) not null,
  Company: string(200)
)
system members (owner)
index (Email);

create or modify persistent entity HD.Agent (
  Name:     string(200) not null,
  Email:    string(200) not null,
  IsActive: boolean default true
);

-- system members clause enables the 4 NoGeneralization boolean flags in BSON.
-- Child entities (generalization) inherit system members from their root ancestor;
-- only root (NoGeneralization) entities declare this clause.
create or modify persistent entity HD.Ticket (
  Subject:     string(500) not null,
  Description: string,
  Status:      HD.TicketStatus   default Draft,
  Priority:    HD.TicketPriority default Normal,
  SLADueAt:   datetime,
  ResolvedAt:  datetime,
  IsOverSLA:   boolean default false
)
system members (owner, createdDate, changedDate, changedBy)
index (Status)
index (Priority)
index (SLADueAt);

create or modify association HD.Ticket_Customer
  from HD.Ticket to HD.Customer
  type reference
  owner default;

-- Nullable: ticket may not yet be assigned to an agent
create or modify association HD.Ticket_Agent
  from HD.Ticket to HD.Agent
  type reference
  owner default;

create or modify persistent entity HD.TicketComment (
  Content:    string not null,
  IsInternal: boolean default false
);

create or modify association HD.TicketComment_Ticket
  from HD.TicketComment to HD.Ticket
  type reference
  owner default;

-- Workflow context entity for escalation approval
create or modify persistent entity HD.EscalationRequest (
  Reason:          string(1000) not null,
  RequestedAt:     datetime,
  RejectionReason: string(1000)
);

create or modify association HD.EscalationRequest_Ticket
  from HD.EscalationRequest to HD.Ticket
  type reference
  owner default;

-- Non-persistent entity: ticket search / filter form
create or modify non-persistent entity HD.TicketSearch (
  SubjectKeyword: string(200),
  StatusFilter:   HD.TicketStatus,
  PriorityFilter: HD.TicketPriority
);

-- Cross-module: ticket may link to a KB article (nullable)
create or modify association HD.Ticket_KBArticle
  from HD.Ticket to KB.Article
  type reference
  owner default;

-- SLA time limits per priority, configurable per environment
create or modify constant HD.SLA_HIGH_HOURS
  type integer
  default 8
  comment 'SLA deadline in hours for High-priority tickets.';

create or modify constant HD.SLA_CRITICAL_HOURS
  type integer
  default 2
  comment 'SLA deadline in hours for Critical-priority tickets. Configure shorter per environment.';

-- ACT_Ticket_Submit: Draft → Open
-- Edge cases: Subject validation (rollback branch), SLA computed from constant
create or modify microflow HD.ACT_Ticket_Submit
  ($Ticket: HD.Ticket)
  returns boolean as $Success
  folder 'Ticket'
begin
  if $Ticket/Subject = '' then
      validation feedback $Ticket/Subject message 'Subject is required';
      return false;
  end if;

  -- Compute SLA due date based on priority.
  -- Hours: Critical=2, High=8, default=24.
  -- MDL has no else-if; use nested if/else.
  if $Ticket/Priority = HD.TicketPriority.Critical then
    change $Ticket (
      Status   = HD.TicketStatus.Open,
      SLADueAt = addHours('[%CurrentDateTime%]', @HD.SLA_CRITICAL_HOURS)
    );
  else
    if $Ticket/Priority = HD.TicketPriority.High then
      change $Ticket (
        Status   = HD.TicketStatus.Open,
        SLADueAt = addHours('[%CurrentDateTime%]', @HD.SLA_HIGH_HOURS)
      );
    else
      change $Ticket (
        Status   = HD.TicketStatus.Open,
        SLADueAt = addHours('[%CurrentDateTime%]', 24)
      );
    end if;
  end if;
  commit $Ticket;
  return true;
end;
/

-- ACT_Ticket_Validate: multi-field validation feedback demo
-- Edge cases:
--   accumulate pattern — collect ALL field errors before returning false
--     (shows all red fields at once, unlike bail-early in ACT_Ticket_Submit)
--   plain attribute path: validation feedback $Obj/Attr message '...';
--   objects clause: validation feedback $Obj/Attr message '{1}...' objects [$Obj/Attr];
--     (objects provides template args for {1}/{2}/... placeholders in message)
create or modify microflow HD.ACT_Ticket_Validate
  ($Ticket: HD.Ticket)
  returns boolean as $Valid
  folder 'Ticket'
begin
  declare $Valid boolean = true;

  -- Plain form: no template args, bail-early on empty subject
  if $Ticket/Subject = '' then
    validation feedback $Ticket/Subject message 'Subject is required.';
    set $Valid = false;
  else
    -- objects form: {1} placeholder bound to the attribute value via objects clause
    if length($Ticket/Subject) < 3 then
      validation feedback $Ticket/Subject message 'Subject ''{1}'' is too short (minimum 3 characters).' objects [$Ticket/Subject];
      set $Valid = false;
    end if;
  end if;

  -- Field: Description — required when Priority is Critical
  if $Ticket/Priority = HD.TicketPriority.Critical then
    if $Ticket/Description = '' or $Ticket/Description = empty then
      validation feedback $Ticket/Description message 'Description is required for Critical tickets.';
      set $Valid = false;
    end if;
  end if;

  return $Valid;
end;
/

-- ACT_Ticket_Assign: Open → InProgress, set Agent
-- Edge case: pre-condition state assertion
create or modify microflow HD.ACT_Ticket_Assign
  ($Ticket: HD.Ticket, $Agent: HD.Agent)
  returns boolean as $Success
  folder 'Ticket'
begin
  if $Ticket/Status != HD.TicketStatus.Open then
      show message 'Only Open tickets can be assigned.' type warning;
      return false;
  end if;
  change $Ticket (
    Status = HD.TicketStatus.InProgress,
    HD.Ticket_Agent = $Agent
  );
  commit $Ticket;
  return true;
end;
/

-- ACT_Ticket_Resolve: InProgress → Resolved
-- Edge case: time comparison to set IsOverSLA flag
create or modify microflow HD.ACT_Ticket_Resolve
  ($Ticket: HD.Ticket)
  returns boolean as $Success
  folder 'Ticket'
begin
  if $Ticket/Status != HD.TicketStatus.InProgress then
      return false;
  end if;
  declare $Now datetime = '[%CurrentDateTime%]';
  declare $IsOver boolean = $Now > $Ticket/SLADueAt and $Ticket/SLADueAt != empty;
  change $Ticket (
    Status     = HD.TicketStatus.Resolved,
    ResolvedAt = $Now,
    IsOverSLA  = $IsOver
  );
  commit $Ticket;
  return true;
end;
/

-- ACT_Ticket_Reopen: Resolved/Closed → Open
-- Edge case: state reversal (backward transition)
create or modify microflow HD.ACT_Ticket_Reopen
  ($Ticket: HD.Ticket)
  returns boolean as $Success
  folder 'Ticket'
begin
  if $Ticket/Status != HD.TicketStatus.Resolved
     and $Ticket/Status != HD.TicketStatus.Closed then
      return false;
  end if;
  change $Ticket (
    Status     = HD.TicketStatus.Open,
    ResolvedAt = empty
  );
  commit $Ticket;
  return true;
end;
/

-- ACT_Ticket_Close: Resolved → Closed (terminal transition)
create or modify microflow HD.ACT_Ticket_Close
  ($Ticket: HD.Ticket)
  returns boolean as $Success
  folder 'Ticket'
begin
  if $Ticket/Status != HD.TicketStatus.Resolved then
      return false;
  end if;
  change $Ticket (Status = HD.TicketStatus.Closed);
  commit $Ticket;
  return true;
end;
/

-- MARK: KnowledgeBase — Microflows

-- ACT_Article_Publish: Draft → Published, validate content
create or modify microflow KB.ACT_Article_Publish
  ($Article: KB.Article)
  returns boolean as $Success
  folder 'Article'
begin
  if $Article/Content = '' or $Article/Content = empty then
      validation feedback $Article/Content message 'Content cannot be empty before publishing.';
      return false;
  end if;
  change $Article (
    Status      = KB.ArticleStatus.Published,
    PublishedAt = '[%CurrentDateTime%]'
  );
  commit $Article;
  return true;
end;
/

-- ACT_Article_Archive: Published → Archived (terminal)
create or modify microflow KB.ACT_Article_Archive
  ($Article: KB.Article)
  returns boolean as $Success
  folder 'Article'
begin
  change $Article (Status = KB.ArticleStatus.Archived);
  commit $Article;
  return true;
end;
/

-- ACT_Ticket_MarkCommentsRead: loop over internal comments, un-flag them
-- Demonstrates: retrieve list + loop activity
create or modify microflow HD.ACT_Ticket_MarkCommentsRead
  ($Ticket: HD.Ticket)
  folder 'Ticket'
begin
  retrieve $Comments from HD.TicketComment
    where [HD.TicketComment_Ticket/HD.Ticket = $Ticket and IsInternal = true]
    limit 100;
  loop $Comment in $Comments
  begin
    change $Comment (IsInternal = false);
    commit $Comment;
  end loop;
  return;
end;
/

-- ACT_EscalationRequest_Cleanup: delete escalation records for a ticket
-- Demonstrates: loop + delete activity
create or modify microflow HD.ACT_EscalationRequest_Cleanup
  ($Ticket: HD.Ticket)
  folder 'Ticket'
begin
  retrieve $Requests from HD.EscalationRequest
    where [HD.EscalationRequest_Ticket/HD.Ticket = $Ticket]
    limit 50;
  loop $Req in $Requests
  begin
    delete $Req;
  end loop;
  return;
end;
/

-- ACT_Ticket_SafeCommit: commit ticket with error rollback
-- Demonstrates: on error rollback pattern
create or modify microflow HD.ACT_Ticket_SafeCommit
  ($Ticket: HD.Ticket)
  returns boolean as $Success
  folder 'Ticket'
begin
  declare $Success boolean = false;
  commit $Ticket on error rollback;
  set $Success = true;
  return $Success;
end;
/

-- DS_OverdueTicketCount: count overdue tickets via aggregate
-- Demonstrates: retrieve list + aggregate count activity
create or modify microflow HD.DS_OverdueTicketCount
  ()
  returns integer as $Count
  folder 'Ticket'
begin
  retrieve $Overdue from HD.Ticket
    where [IsOverSLA = true]
    limit 0;
  $Count = COUNT($Overdue);
  return $Count;
end;
/

-- DS_TicketsByCompany: retrieve tickets for a given customer company
-- Demonstrates: multi-hop association path in XPath
--   Path: Ticket → HD.Ticket_Customer (assoc) → HD.Customer → Company attribute
create or modify microflow HD.DS_TicketsByCompany
  ($Company: String)
  returns list of HD.Ticket as $Tickets
  folder 'Ticket'
begin
  retrieve $Tickets from HD.Ticket
    where [HD.Ticket_Customer/HD.Customer/Company = $Company]
    limit 50;
  return $Tickets;
end;
/

-- DS_MyTickets: retrieve all tickets created by the currently logged-in user
-- Demonstrates: [%CurrentUser%] system token in XPath constraint
create or modify microflow HD.DS_MyTickets
  ()
  returns list of HD.Ticket as $Tickets
  folder 'Ticket'
begin
  retrieve $Tickets from HD.Ticket
    where [System.owner = '[%CurrentUser%]']
    limit 0;
  return $Tickets;
end;
/

-- DS_OpenHighTickets: retrieve open high-priority tickets
-- Demonstrates: enum values as string literals in XPath (not qualified names)
--   'Open' is the database-level string for HD.TicketStatus.Open
--   'High' is the database-level string for HD.TicketPriority.High
create or modify microflow HD.DS_OpenHighTickets
  ()
  returns list of HD.Ticket as $Tickets
  folder 'Ticket'
begin
  retrieve $Tickets from HD.Ticket
    where [Status = 'Open' and Priority = 'High']
    limit 0;
  return $Tickets;
end;
/

-- DS_TicketPage: retrieve a page of tickets with offset, limit, and sort
-- Demonstrates:
--   limit N    — CustomRange with limit expression (max rows)
--   offset M   — CustomRange with offset expression (skip M rows for pagination)
--   sort by    — SortItemList with ascending/descending columns
-- Pagination pattern: page 1 = offset 0 limit 20, page 2 = offset 20 limit 20, etc.
create or modify microflow HD.DS_TicketPage
  ($PageIndex: Integer, $PageSize: Integer)
  returns list of HD.Ticket as $Tickets
  folder 'Ticket'
begin
  declare $Offset integer = ($PageIndex - 1) * $PageSize;
  retrieve $Tickets from HD.Ticket
    where [Status != 'Closed']
    sort by SLADueAt asc, Priority desc
    limit $PageSize
    offset $Offset;
  return $Tickets;
end;
/

-- DS_RecentCriticalTickets: retrieve most-recently-created critical tickets
-- Demonstrates: sort by with a single column descending + fixed limit
-- Note: system member attributes (createdDate, changedDate, owner, changedBy) are
-- referenced bare (no Module.Entity prefix); the executor qualifies them automatically.
create or modify microflow HD.DS_RecentCriticalTickets
  ()
  returns list of HD.Ticket as $Tickets
  folder 'Ticket'
begin
  retrieve $Tickets from HD.Ticket
    where [Priority = 'Critical']
    sort by createdDate desc
    limit 10;
  return $Tickets;
end;
/

-- MARK: HelpDesk — Nanoflows

-- NF_Ticket_QuickCreate: create + commit a Draft ticket from the client
-- Demonstrates: nanoflow creating and committing a persistent entity
create or modify nanoflow HD.NF_Ticket_QuickCreate
  ($Customer: HD.Customer, $Subject: string)
  returns HD.Ticket as $Ticket
  folder 'Ticket'
begin
  $Ticket = create HD.Ticket (
    Subject  = $Subject,
    Status   = HD.TicketStatus.Draft,
    Priority = HD.TicketPriority.Normal,
    HD.Ticket_Customer = $Customer
  );
  commit $Ticket;
  return $Ticket;
end;
/

-- NF_TicketSearch_Apply: retrieve tickets matching search criteria
-- Demonstrates: nanoflow querying the database with XPath
create or modify nanoflow HD.NF_TicketSearch_Apply
  ($Search: HD.TicketSearch)
  returns list of HD.Ticket as $Tickets
  folder 'Ticket/Search'
begin
  -- Simplified: full retrieve (XPath cross-object reference to non-persistent
  -- entity not supported in this context; filtering done client-side or via
  -- separate microflow call). Demonstrates nanoflow DB retrieve capability.
  retrieve $Tickets from HD.Ticket limit 100;
  return $Tickets;
end;
/

-- NF_Priority_GetLabel: pure client-side computation, returns CSS class string
-- Demonstrates: nanoflow with no DB access, if/else chain, string return
-- Note: enumeration types as nanoflow params cause CE1613 in current BSON writer;
-- parameter uses string (e.g. 'Critical', 'High') as workaround.
create or modify nanoflow HD.NF_Priority_GetLabel
  ($PriorityStr: string)
  returns string as $CSSClass
  folder 'Ticket'
begin
  -- MDL uses nested if/else (no else-if); 'set' keyword for variable reassignment
  declare $CSSClass string = 'badge-default';
  if $PriorityStr = 'Critical' then
    set $CSSClass = 'badge-danger';
  else
    if $PriorityStr = 'High' then
      set $CSSClass = 'badge-warning';
    else
      if $PriorityStr = 'Normal' then
        set $CSSClass = 'badge-info';
      end if;
    end if;
  end if;
  return $CSSClass;
end;
/

-- MARK: KnowledgeBase — Nanoflows

-- SUB_Article_TruncateContent must be defined BEFORE the nanoflow that calls it
create or modify microflow KB.SUB_Article_TruncateContent
  ($Article: KB.Article)
  returns string as $Preview
  folder 'Article'
begin
  declare $Preview string = $Article/Content;
  return $Preview;
end;
/

-- NF_Article_FormatPreview: call a microflow from a nanoflow
-- Demonstrates: nanoflow → microflow call (server-side truncation)
create or modify nanoflow KB.NF_Article_FormatPreview
  ($Article: KB.Article)
  returns string as $Preview
  folder 'Article'
begin
  $Preview = call microflow KB.SUB_Article_TruncateContent(Article = $Article);
  return $Preview;
end;
/

-- MARK: HelpDesk — Sub-Workflow (WF_SUB_ManagerReview)

-- Required pages for workflow (must exist before workflow is created)
-- CE7410: workflow user task page must declare a WorkflowUserTask parameter
create or replace page HD.EscalationReview_Form
(
  title: 'Escalation Review',
  layout: Atlas_Core.Atlas_Default,
  folder: 'Escalation',
  params: { $WorkflowUserTask: System.WorkflowUserTask }
)
{
  layoutgrid lgMain {
    row rMain {
      column cMain (desktopwidth: 12) {
        dynamictext txtTitle (content: 'Manager Review', rendermode: H2)
      }
    }
  }
};

create or replace page HD.EscalationWorkflow_Overview
(
  title: 'Escalation Workflow',
  layout: Atlas_Core.Atlas_Default,
  folder: 'Escalation'
)
{
  layoutgrid lgMain {
    row rMain {
      column cMain (desktopwidth: 12) {
        dynamictext txtTitle (content: 'Escalation Overview', rendermode: H2)
      }
    }
  }
};

-- User assignment targeting microflow (WFA_ prefix per naming conventions)
create or modify microflow HD.WFA_GetManagerAssignees
  ($workflow: System.Workflow, $EscalationRequest: HD.EscalationRequest)
  returns list of System.User as $Users
  folder 'Escalation'
begin
  -- Simplified: full user retrieve (role-based XPath on System.UserRoles
  -- requires specific association path; use admin configuration in production)
  retrieve $Users from System.User limit 10;
  return $Users;
end;
/

-- WFS_ microflows: called directly by workflow activities (WFS_ prefix)
create or modify microflow HD.WFS_SendReminder
  ($EscalationRequest: HD.EscalationRequest)
  folder 'Escalation'
begin
  log info 'Escalation reminder sent for request ' + toString($EscalationRequest/Reason);
  return;
end;
/

create or modify microflow HD.WFS_Approve
  ($EscalationRequest: HD.EscalationRequest)
  folder 'Escalation'
begin
  retrieve $Ticket from HD.Ticket
    where [HD.EscalationRequest_Ticket/HD.EscalationRequest = $EscalationRequest]
    limit 1;
  if $Ticket != empty then
    change $Ticket (Priority = HD.TicketPriority.Critical);
    commit $Ticket;
  end if;
  return;
end;
/

create or modify microflow HD.WFS_Reject
  ($EscalationRequest: HD.EscalationRequest)
  folder 'Escalation'
begin
  change $EscalationRequest (RejectionReason = 'Rejected by manager review board.');
  commit $EscalationRequest;
  return;
end;
/

-- Sub-workflow: manager review with decision routing and multi-user task fallback
-- Elements covered:
--   User task (xpath targeting), Decision (boolean expr with true/false paths),
--   Multi-user task (majority, nested in decision false path),
--   Call microflow, Non-interrupting boundary event (12h reminder)
create or replace workflow HD.WF_SUB_ManagerReview
  parameter $WorkflowContext: HD.EscalationRequest
  display 'Manager Review'
  overview page HD.EscalationWorkflow_Overview
begin
  user task UT_PrimaryReview 'Primary Review'
    page HD.EscalationReview_Form
    targeting users microflow HD.WFA_GetManagerAssignees
    description 'Review escalation request and decide: Approve or escalate to board'
    outcomes
      'Approve' {
        call microflow HD.WFS_Approve;
      }
      'Escalate' {
        multi user task UT_SeniorReview 'Senior Board Review'
          page HD.EscalationReview_Form
          targeting users microflow HD.WFA_GetManagerAssignees
          completion method majority
          outcomes
            'Approve' { call microflow HD.WFS_Approve; }
            'Reject'  { call microflow HD.WFS_Reject;  }
          ;
      }
  ;
end workflow;
/

-- MARK: HelpDesk — Parent Workflow (WF_TicketEscalation)

-- WFS_ microflows used by parent workflow
create or modify microflow HD.WFS_Escalation_Initialize
  ($EscalationRequest: HD.EscalationRequest)
  folder 'Escalation'
begin
  change $EscalationRequest (RequestedAt = '[%CurrentDateTime%]');
  commit $EscalationRequest;
  return;
end;
/

create or modify microflow HD.WFS_AutoReject
  ($EscalationRequest: HD.EscalationRequest)
  folder 'Escalation'
begin
  change $EscalationRequest (RejectionReason = 'Auto-rejected: no manager response within 48 hours.');
  commit $EscalationRequest;
  return;
end;
/

create or modify microflow HD.WFS_UpdateTicketPriority
  ($EscalationRequest: HD.EscalationRequest)
  folder 'Escalation'
begin
  retrieve $Ticket from HD.Ticket
    where [HD.EscalationRequest_Ticket/HD.EscalationRequest = $EscalationRequest]
    limit 1;
  if $Ticket != empty then
    change $Ticket (Priority = HD.TicketPriority.Critical, Status = HD.TicketStatus.InProgress);
    commit $Ticket;
  end if;
  return;
end;
/

create or modify microflow HD.WFS_NotifyAgent
  ($EscalationRequest: HD.EscalationRequest)
  folder 'Escalation'
begin
  log info 'Agent notified: escalation approved for request ' + toString($EscalationRequest/Reason);
  return;
end;
/

-- Parent workflow: full escalation with all major workflow element types
-- Elements covered:
--   Call microflow, Decision (boolean expr), Wait for notification,
--   Call workflow (parent→child), Parallel split,
--   Non-interrupting boundary event (12h reminder on wait-for-notification),
--   Interrupting boundary event (48h timeout on call workflow)
create or replace workflow HD.WF_TicketEscalation
  parameter $WorkflowContext: HD.EscalationRequest
  display 'Ticket Escalation'
  overview page HD.EscalationWorkflow_Overview
begin
  call microflow HD.WFS_Escalation_Initialize;
  -- $WorkflowContext accesses the business context entity (HD.EscalationRequest).
  -- $WorkflowInstance accesses the System.Workflow runtime instance (State, StartTime, etc.).
  -- Both are always available in workflow expressions.
  decision '$WorkflowContext/Reason = empty and $WorkflowInstance/State = System.WorkflowState.Completed'
    outcomes
      true -> {
        call microflow HD.WFS_AutoReject;
      }
      false -> {
        wait for notification comment 'WaitForManagerAvailable';
        call workflow HD.WF_SUB_ManagerReview;
        parallel split
          path 1 { call microflow HD.WFS_UpdateTicketPriority; }
          path 2 { call microflow HD.WFS_NotifyAgent; }
        ;
      }
  ;
end workflow;
/

-- MARK: HelpDesk — Workflow Support Microflows (all 13 activities)

-- 1. Call workflow — trigger the escalation workflow from a button microflow
create or modify microflow HD.ACT_StartEscalation
  ($Ticket: HD.Ticket, $Reason: string)
  returns boolean as $Success
  folder 'Escalation'
begin
  if $Ticket/Status != HD.TicketStatus.InProgress then
    return false;
  end if;
  $EscalationRequest = create HD.EscalationRequest (
    Reason          = $Reason,
    RequestedAt     = '[%CurrentDateTime%]',
    HD.EscalationRequest_Ticket = $Ticket
  );
  commit $EscalationRequest;
  -- Activity: Call workflow (start workflow with context entity)
  -- TODO: verify exact syntax for starting a workflow from microflow;
  -- standard form is: call workflow Module.WFName($ContextParam)
  call workflow HD.WF_TicketEscalation (EscalationRequest = $EscalationRequest);
  return true;
end;
/

-- 2. Workflow create event handler (WFC_ prefix)
create or modify microflow HD.WFC_EscalationRequest_OnCreate
  ($EscalationRequest: HD.EscalationRequest)
  folder 'Escalation'
begin
  log info 'EscalationRequest created: ' + toString($EscalationRequest/Reason);
  return;
end;
/

-- 3. Change workflow state — Pause / Unpause / Abort / Retry
create or modify microflow HD.ACT_Workflow_ChangeState
  ($Workflow: System.Workflow, $Operation: string)
  folder 'Escalation/WorkflowAdmin'
begin
  if $Operation = 'Pause' then
    workflow operation pause $Workflow;
  else
    if $Operation = 'Unpause' then
      workflow operation unpause $Workflow;
    else
      workflow operation abort $Workflow reason 'Administratively aborted';
    end if;
  end if;
  return;
end;
/

-- 4. Complete user task (system-side completion)
create or modify microflow HD.ACT_Workflow_CompleteTask
  ($UserTask: System.WorkflowUserTask, $Outcome: string)
  folder 'Escalation/WorkflowAdmin'
begin
  set task outcome $UserTask 'Approve';
  -- Note: SET TASK OUTCOME requires a string literal, not a variable.
  -- The $Outcome parameter is accepted for dispatch logic but the outcome value
  -- must be specified at design time. Use if/else to dispatch on $Outcome.
  return;
end;
/

-- 5. Generate jump-to options (no return value — CE0109 fix).
create or modify microflow HD.ACT_Workflow_GenerateJumpTo
  ($Workflow: System.Workflow)
  folder 'Escalation/WorkflowAdmin'
begin
  generate jump to options for $Workflow as HD.WF_TicketEscalation;
  return;
end;
/

-- 6. Apply a pre-generated jump-to option (System.WorkflowJumpToDetails).
-- Typical pattern: admin page calls ACT_Workflow_GenerateJumpTo, user selects a target
-- activity from the displayed WorkflowJumpToDetails, then this microflow applies it.
create or modify microflow HD.ACT_Workflow_ApplyJumpTo
  ($JumpOption: System.WorkflowJumpToDetails)
  folder 'Escalation/WorkflowAdmin'
begin
  apply jump to option $JumpOption;
  return;
end;
/

-- 7. Retrieve workflow activity records
-- Note: returns Nothing — get workflow activity records output variable
-- not visible to Mendix end event (CE0109 workaround pending fix)
create or modify microflow HD.ACT_Workflow_GetHistory
  ($Workflow: System.Workflow)
  folder 'Escalation/WorkflowAdmin'
begin
  get workflow activity records $Workflow;
  return;
end;
/

-- 8. Retrieve workflow context
create or modify microflow HD.ACT_Workflow_GetContext
  ($Workflow: System.Workflow)
  folder 'Escalation/WorkflowAdmin'
begin
  get workflow data $Workflow as HD.WF_TicketEscalation;
  return;
end;
/

-- 9. Retrieve workflow instances
create or modify microflow HD.DS_WorkflowInstances
  ($EscalationRequest: HD.EscalationRequest)
  folder 'Escalation/WorkflowAdmin'
begin
  get workflows for $EscalationRequest;
  return;
end;
/

-- 10. Show user task page
create or modify microflow HD.ACT_Workflow_ShowTaskPage
  ($UserTask: System.WorkflowUserTask)
  folder 'Escalation/WorkflowAdmin'
begin
  open user task $UserTask;
  return;
end;
/

-- 11. Show workflow admin page
create or modify microflow HD.ACT_Workflow_ShowAdminPage
  ($Workflow: System.Workflow)
  folder 'Escalation/WorkflowAdmin'
begin
  open workflow $Workflow;
  return;
end;
/

-- 12. Lock workflow (System.WorkflowDefinition = the workflow type/definition object)
create or modify microflow HD.ACT_Workflow_Lock
  ($Workflow: System.WorkflowDefinition)
  folder 'Escalation/WorkflowAdmin'
begin
  lock workflow $Workflow;
  return;
end;
/

-- 13. Unlock workflow
create or modify microflow HD.ACT_Workflow_Unlock
  ($Workflow: System.WorkflowDefinition)
  folder 'Escalation/WorkflowAdmin'
begin
  unlock workflow $Workflow;
  return;
end;
/

-- Notify the WaitForManagerAvailable activity in WF_TicketEscalation.
-- CE0109 fix: notify workflow output variable cannot be used as return value.
create or modify microflow HD.ACT_Workflow_Notify
  ($Workflow: System.Workflow)
  folder 'Escalation/WorkflowAdmin'
begin
  notify workflow $Workflow activity HD.WF_TicketEscalation.WaitForManagerAvailable;
  return;
end;
/

-- MARK: Pages — KnowledgeBase

-- KB Article overview: Gallery (left) + DataView master-detail (right)
-- Pattern B: Gallery selection:single + filter bar, DataView datasource:selection
-- KB Article overview: Gallery (list) + DataView (detail) master-detail
-- Pattern B: Gallery selection:single + filter bar, DataView datasource:selection
-- Both gallery and dataview are placed in the same layout column so that the
-- DataView can listen to the Gallery's selection (Mendix scoping rule: selection
-- listener must be in the same container scope as the source widget — cross-sibling
-- LayoutGrid column binding triggers CE3637).
-- Side-by-side display is achieved with CSS classes on the inner containers.
create or replace page KB.Article_Overview
(
  title: 'Knowledge Base',
  layout: Atlas_Core.Atlas_Default,
  folder: 'Article'
)
{
  gallery artGallery (
    datasource: database from KB.Article sort by PublishedAt desc,
    selection: single
  ) {
    filter filterBar {
      dropdownfilter fStatus (attributes: [KB.Article.Status])
    }
    template template1 {
      dynamictext txtTitle  (content: '{1}', contentparams: [{1} = Title],  rendermode: H4)
      dynamictext txtStatus (content: '{1}', contentparams: [{1} = Status])
    }
  }
  dataview dvArticleDetail (datasource: selection artGallery) {
    dynamictext txtDetailTitle   (content: '{1}', contentparams: [{1} = Title],       rendermode: H2)
    dynamictext txtDetailStatus  (content: '{1}', contentparams: [{1} = Status])
    dynamictext txtPublished     (content: '{1}', contentparams: [{1} = PublishedAt])
    dynamictext txtContent       (content: '{1}', contentparams: [{1} = Content])
    footer ftrActions {
      actionbutton btnPublish (
        caption: 'Publish',
        action: microflow KB.ACT_Article_Publish (Article: $currentObject),
        buttonstyle: primary
      )
      actionbutton btnArchive (
        caption: 'Archive',
        action: microflow KB.ACT_Article_Archive (Article: $currentObject),
        buttonstyle: default
      )
    }
  }
};

create or replace page KB.Article_Detail
(
  title: 'Article',
  layout: Atlas_Core.Atlas_Default,
  folder: 'Article',
  params: { $Article: KB.Article }
)
{
  layoutgrid lgMain {
    row rMain {
      column cMain (desktopwidth: 9) {
        dataview dvArticle (datasource: $Article) {
          dynamictext txtTitle   (content: 'Article Title',   rendermode: H1)
          dynamictext txtContent_ (content: 'Article Body Text')
        }
      }
      column cSidebar (desktopwidth: 3) {
        datagrid dgRatings (
          datasource: database KB.ArticleRating
        ) {
          column colScore   (attribute: Score,   caption: 'Score')
          column colComment (attribute: Comment, caption: 'Comment')
        }
      }
    }
  }
};

-- MARK: Pages — HelpDesk

-- ACT_Ticket_New: create without commit, open edit page
-- Fixes: create_object commits immediately (empty tickets appear in DB before Save)
create or modify microflow HD.ACT_Ticket_New
  ()
  returns HD.Ticket as $Ticket
  folder 'Ticket'
begin
  $Ticket = create HD.Ticket (
    Status   = HD.TicketStatus.Draft,
    Priority = HD.TicketPriority.Normal
  );
  show page HD.Ticket_NewEdit (Ticket: $Ticket);
  return $Ticket;
end;
/

-- Ticket overview: DataGrid2 CRUD overview
-- Pattern A: controlbar New button, column filters, sort, Edit action column
-- Fixes: sort by createdDate desc (SLADueAt NULLs sorted to end, hiding new tickets)
--        btnNew calls ACT_Ticket_New microflow (no premature commit)
create or replace page HD.Ticket_Overview
(
  title: 'Tickets',
  layout: Atlas_Core.Atlas_Default,
  folder: 'Ticket'
)
{
  layoutgrid lgMain {
    row rMain {
      column cMain (desktopwidth: 12) {
        datagrid dgTickets (
          datasource: database from HD.Ticket sort by createdDate desc,
          PageSize: 20,
          PagingPosition: both
        ) {
          controlbar cb1 {
            actionbutton btnNew (
              caption: 'New Ticket',
              action: microflow HD.ACT_Ticket_New,
              buttonstyle: primary
            )
          }
          column colSubject   (attribute: Subject,   caption: 'Subject')
          column colStatus    (attribute: Status,    caption: 'Status',   ColumnWidth: manual, Size: 120)
          column colPriority  (attribute: Priority,  caption: 'Priority', ColumnWidth: manual, Size: 100)
          column colSLADueAt  (attribute: SLADueAt,  caption: 'SLA Due',  ColumnWidth: manual, Size: 140)
          column colIsOverSLA (attribute: IsOverSLA, caption: 'Overdue',  ColumnWidth: manual, Size: 90)
          column colActions   (caption: 'Actions', ShowContentAs: customContent, ColumnWidth: manual, Size: 80) {
            actionbutton btnEdit (
              caption: 'Edit',
              action: show_page HD.Ticket_Detail (Ticket: $currentObject),
              buttonstyle: default
            )
          }
        }
      }
    }
  }
};

-- Agent selection popup: DataGrid (selection:single) + microflow close_page
-- Pattern D: popup selection — lists HD.Agent, calls ACT_Ticket_Assign, closes popup
-- Must be defined before HD.Ticket_Detail which references it via show_page.
create or replace page HD.Agent_Select
(
  title: 'Select Agent',
  layout: Atlas_Core.PopupLayout,
  folder: 'Ticket',
  params: { $Ticket: HD.Ticket }
)
{
  datagrid dgAgents (
    datasource: database from HD.Agent sort by Name asc,
    PageSize: 15,
    selection: single
  ) {
    controlbar cb1 {
      actionbutton btnAssign (
        caption: 'Assign',
        action: microflow HD.ACT_Ticket_Assign (Ticket: $Ticket, Agent: $currentObject) close_page,
        buttonstyle: primary
      )
    }
    column colName     (attribute: Name,     caption: 'Name')
    column colEmail    (attribute: Email,    caption: 'Email')
    column colIsActive (attribute: IsActive, caption: 'Active', ColumnWidth: manual, Size: 80)
  }
};

-- Ticket detail: DataView (page param) + ActionButtons + nested association DataGrid
-- Pattern C: datasource: $Ticket/HD.TicketComment_Ticket/HD.TicketComment (no XPath needed)
create or replace page HD.Ticket_Detail
(
  title: 'Ticket',
  layout: Atlas_Core.Atlas_Default,
  folder: 'Ticket',
  params: { $Ticket: HD.Ticket }
)
{
  layoutgrid lgMain {
    row rHeader {
      column cHeader (desktopwidth: 12) {
        dataview dvTicket (datasource: $Ticket) {
          dynamictext txtSubject  (content: '{1}', contentparams: [{1} = Subject],  rendermode: H2)
          dynamictext txtStatus   (content: '{1}', contentparams: [{1} = Status])
          dynamictext txtPriority (content: '{1}', contentparams: [{1} = Priority])
          dynamictext txtSLADue   (content: '{1}', contentparams: [{1} = SLADueAt])
          footer ftrActions {
            actionbutton btnSubmit (
              caption: 'Submit',
              action: microflow HD.ACT_Ticket_Submit (Ticket: $Ticket),
              buttonstyle: primary
            )
            actionbutton btnResolve (
              caption: 'Resolve',
              action: microflow HD.ACT_Ticket_Resolve (Ticket: $Ticket),
              buttonstyle: default
            )
            actionbutton btnReopen (
              caption: 'Reopen',
              action: microflow HD.ACT_Ticket_Reopen (Ticket: $Ticket),
              buttonstyle: default
            )
            actionbutton btnAssignAgent (
              caption: 'Assign Agent',
              action: show_page HD.Agent_Select (Ticket: $Ticket),
              buttonstyle: default
            )
          }
        }
      }
    }
    row rComments {
      column cComments (desktopwidth: 12) {
        datagrid dgComments (
          datasource: $Ticket/HD.TicketComment_Ticket/HD.TicketComment
        ) {
          column colContent_    (attribute: Content,    caption: 'Comment')
          column colIsInternal (attribute: IsInternal, caption: 'Internal', ColumnWidth: manual, Size: 90)
        }
      }
    }
  }
};

-- Popup: non-persistent entity search form
create or replace page HD.TicketSearch_Form
(
  title: 'Search Tickets',
  layout: Atlas_Core.PopupLayout,
  folder: 'Ticket/Search',
