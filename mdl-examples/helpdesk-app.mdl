-- MARK: Security — Module Roles

-- KnowledgeBase: 3 module roles
create module role KB.Reader;
create module role KB.Contributor;
create module role KB.Admin;

-- HelpDesk: 3 module roles (no Admin module role — admin access via user role composition)
create module role HD.CustomerRole;
create module role HD.AgentRole;
create module role HD.ManagerRole;

-- MARK: Security — User Roles & Grants

alter project security level production;

-- Entity access — KnowledgeBase

-- KB.Reader: only Published articles (XPath), own ratings only
grant KB.Reader on KB.Article (read *)
  where '[Status = ''Published'']';
grant KB.Reader on KB.Category (read *);
grant KB.Reader on KB.Tag (read *);
-- Explicit member list: reader sees Score+Comment only; System.owner XPath for row filter.
-- This demonstrates 'read (A, B)' syntax vs the default 'read *'.
grant KB.Reader on KB.ArticleRating (read (Score, Comment, KB.ArticleRating_Article), write (Score, Comment))
  where '[System.owner=''[%CurrentUser%]'']';
grant KB.Reader on KB.ArticleTag (read *);

-- KB.Contributor: full article lifecycle
grant KB.Contributor on KB.Article (create, read *, write *, delete);
grant KB.Contributor on KB.ArticleRating (create, read *, write *, delete);
grant KB.Contributor on KB.ArticleTag (create, read *, write *, delete);
grant KB.Contributor on KB.Category (create, read *, write *);
grant KB.Contributor on KB.Tag (create, read *, write *);

-- KB.Admin: unrestricted
grant KB.Admin on KB.Article (create, read *, write *, delete);
grant KB.Admin on KB.ArticleRating (create, read *, write *, delete);
grant KB.Admin on KB.ArticleTag (create, read *, write *, delete);
grant KB.Admin on KB.Category (create, read *, write *, delete);
grant KB.Admin on KB.Tag (create, read *, write *, delete);

-- Microflow / nanoflow grants — KnowledgeBase
grant execute on microflow KB.ACT_Article_Publish to KB.Contributor, KB.Admin;
grant execute on microflow KB.ACT_Article_Archive to KB.Contributor, KB.Admin;
grant execute on nanoflow KB.NF_Article_FormatPreview to KB.Reader, KB.Contributor, KB.Admin;

-- Entity access — HelpDesk

-- CustomerRole: explicit member list — customer sees/edits own ticket fields only.
-- Demonstrates explicit 'read (A,B)' alongside System.owner multi-hop XPath.
grant HD.CustomerRole on HD.Ticket (create,
  read (Subject, Description, Status, Priority, SLADueAt, ResolvedAt, IsOverSLA, HD.Ticket_Customer, HD.Ticket_Agent, HD.Ticket_KBArticle),
  write (Subject, Description, HD.Ticket_KBArticle))
  where '[System.owner=''[%CurrentUser%]'']';
grant HD.CustomerRole on HD.TicketComment (create, read *)
  where '[IsInternal = false]';
grant HD.CustomerRole on HD.Customer (read *, write *);
grant HD.CustomerRole on HD.TicketSearch (read *, write *);

-- AgentRole: all tickets, all comments including Internal
grant HD.AgentRole on HD.Ticket (create, read *, write *);
grant HD.AgentRole on HD.TicketComment (create, read *, write *);
grant HD.AgentRole on HD.Customer (read *);
grant HD.AgentRole on HD.Agent (read *);
grant HD.AgentRole on HD.EscalationRequest (create, read *);
grant HD.AgentRole on HD.TicketSearch (read *, write *);

-- ManagerRole: AgentRole + approve escalations + delete tickets
grant HD.ManagerRole on HD.Ticket (create, read *, write *, delete);
grant HD.ManagerRole on HD.TicketComment (create, read *, write *, delete);
grant HD.ManagerRole on HD.Customer (read *, write *);
grant HD.ManagerRole on HD.Agent (read *, write *);
grant HD.ManagerRole on HD.EscalationRequest (create, read *, write *, delete);
grant HD.ManagerRole on HD.TicketSearch (read *, write *);

-- Microflow / nanoflow grants — HelpDesk
grant execute on microflow HD.ACT_Ticket_New     to HD.CustomerRole, HD.AgentRole, HD.ManagerRole;
grant execute on microflow HD.ACT_Ticket_Validate to HD.CustomerRole, HD.AgentRole, HD.ManagerRole;
grant execute on microflow HD.ACT_Ticket_Submit  to HD.CustomerRole, HD.AgentRole, HD.ManagerRole;
grant execute on microflow HD.ACT_Ticket_Assign  to HD.AgentRole, HD.ManagerRole;
grant execute on microflow HD.ACT_Ticket_Resolve to HD.AgentRole, HD.ManagerRole;
grant execute on microflow HD.ACT_Ticket_Reopen  to HD.AgentRole, HD.ManagerRole;
grant execute on microflow HD.ACT_Ticket_Close   to HD.AgentRole, HD.ManagerRole;
grant execute on microflow HD.ACT_StartEscalation to HD.AgentRole, HD.ManagerRole;
grant execute on microflow HD.ACT_Workflow_ChangeState  to HD.ManagerRole;
grant execute on microflow HD.ACT_Workflow_Lock         to HD.ManagerRole;
grant execute on microflow HD.ACT_Workflow_Unlock       to HD.ManagerRole;
grant execute on microflow HD.ACT_Workflow_Notify          to HD.ManagerRole;
grant execute on microflow HD.ACT_Workflow_CompleteTask     to HD.ManagerRole;
grant execute on microflow HD.ACT_Workflow_GenerateJumpTo   to HD.ManagerRole;
grant execute on microflow HD.ACT_Workflow_ApplyJumpTo      to HD.ManagerRole;
grant execute on microflow HD.ACT_Workflow_GetHistory       to HD.ManagerRole;
grant execute on microflow HD.ACT_Workflow_GetContext       to HD.ManagerRole;
grant execute on microflow HD.DS_WorkflowInstances          to HD.ManagerRole;
grant execute on microflow HD.ACT_EscalationRequest_Cleanup to HD.AgentRole, HD.ManagerRole;
grant execute on nanoflow  HD.NF_Priority_GetLabel          to HD.CustomerRole, HD.AgentRole, HD.ManagerRole;
grant execute on nanoflow  HD.NF_TicketSearch_Apply         to HD.CustomerRole, HD.AgentRole, HD.ManagerRole;
grant execute on nanoflow  HD.NF_Ticket_QuickCreate         to HD.CustomerRole, HD.AgentRole;

-- Page grants
grant view on page HD.Ticket_Overview      to HD.CustomerRole, HD.AgentRole, HD.ManagerRole; -- re-grant after create or replace page
grant view on page HD.Ticket_Detail        to HD.CustomerRole, HD.AgentRole, HD.ManagerRole;
grant view on page HD.TicketSearch_Form    to HD.CustomerRole, HD.AgentRole, HD.ManagerRole;
grant view on page HD.Agent_Select         to HD.AgentRole, HD.ManagerRole;
grant view on page HD.Ticket_NewEdit       to HD.CustomerRole, HD.AgentRole, HD.ManagerRole;
grant view on page KB.Article_NewEdit      to KB.Contributor, KB.Admin;
grant view on page HD.EscalationReview_Form   to HD.ManagerRole;
grant view on page HD.EscalationWorkflow_Overview to HD.ManagerRole;
grant view on page KB.Article_Overview     to KB.Reader, KB.Contributor, KB.Admin;
grant view on page KB.Article_Detail       to KB.Reader, KB.Contributor, KB.Admin;

-- User roles: 4, mapping module roles
-- Note: Administrator uses Administration module built-in + composition of module roles

-- MARK: Security — User Roles

create or modify user role Customer (System.User, HD.CustomerRole, KB.Reader, Atlas_Core.User);
create or modify user role Agent (System.User, HD.AgentRole, KB.Contributor, Atlas_Core.User);
create or modify user role Manager (System.User, HD.ManagerRole, KB.Contributor, Atlas_Core.User);

-- MARK: Security — Demo Users

alter project security demo users on;

create or modify demo user 'demo_customer@helpdesk.test' password 'Dem0Customer#2026' (Customer);
create or modify demo user 'demo_agent@helpdesk.test'    password 'Dem0Agent#2026'    (Agent);
create or modify demo user 'demo_manager@helpdesk.test'  password 'Dem0Manager#2026'  (Manager);

-- Language setting: required for demo user password sync at runtime
alter settings LANGUAGE DefaultLanguageCode = 'en_US';

-- MARK: Navigation

-- Responsive profile: role-derived visibility (no roles() on menu items —
-- visibility is automatically derived from page access permissions)
create or replace navigation Responsive
  home page HD.Ticket_Overview for Customer
  home page HD.Ticket_Overview for Agent
  home page HD.EscalationWorkflow_Overview for Manager
  home page MyFirstModule.Home_Web
  login page Administration.login
  menu (
    menu item 'My Tickets'    page HD.Ticket_Overview;
    menu item 'Knowledge Base' page KB.Article_Overview;
    menu 'Ticket Management' (
      menu item 'All Tickets'          page HD.Ticket_Overview;
      menu item 'Escalation Approval'  page HD.EscalationWorkflow_Overview;
      menu item 'Workflow Management'  page HD.EscalationWorkflow_Overview;
    );
    menu item 'Administration' page Administration.Account_Overview;
  );

-- MARK: Folder Organization — equivalent move commands
-- These move commands are equivalent to the inline folder declarations above.
-- Use this pattern to reorganize an existing flat project without modifying
-- every create statement.

-- KB Module
move microflow KB.ACT_Article_Publish          to folder 'Article';
move microflow KB.ACT_Article_Archive          to folder 'Article';
move microflow KB.SUB_Article_TruncateContent  to folder 'Article';
move nanoflow  KB.NF_Article_FormatPreview     to folder 'Article';
move page      KB.Article_Overview             to folder 'Article';
move page      KB.Article_Detail               to folder 'Article';
move page      KB.Article_NewEdit              to folder 'Article';

-- HD Module — Ticket
move microflow HD.ACT_Ticket_New               to folder 'Ticket';
move microflow HD.ACT_Ticket_Validate          to folder 'Ticket';
move microflow HD.ACT_Ticket_Submit            to folder 'Ticket';
move microflow HD.ACT_Ticket_Assign            to folder 'Ticket';
move microflow HD.ACT_Ticket_Resolve           to folder 'Ticket';
move microflow HD.ACT_Ticket_Reopen            to folder 'Ticket';
move microflow HD.ACT_Ticket_Close             to folder 'Ticket';
move microflow HD.ACT_Ticket_SafeCommit        to folder 'Ticket';
move microflow HD.ACT_Ticket_MarkCommentsRead  to folder 'Ticket';
move microflow HD.ACT_EscalationRequest_Cleanup to folder 'Ticket';
move microflow HD.DS_OverdueTicketCount        to folder 'Ticket';
