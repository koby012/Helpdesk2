{
  "env": {
    "MXCLI_QUIET": "1"
  },
  "permissions": {
    "allow": [
      "Bash(./mxcli:*)",
      "Bash(./mxcli *)",
      "Bash(./mxcli.exe)",
      "Bash(* ./mxcli.exe *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(grep -r*)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(playwright-cli:*)",
      "Bash(playwright-cli *)",
      "Bash(./mxcli.exe exec *)",
      "Bash(docker compose *)",
      "Bash(\"./mxcli.exe\" -p Helpdesk2.mpr -c \"SHOW HELP\")",
      "Bash(\"./mxcli.exe\" docker *)",
      "Bash(\"./mxcli.exe\" check *)",
      "Bash(\"./mxcli.exe\" -p Helpdesk2.mpr -c \"SHOW USER ROLES\")",
      "Bash(\"./mxcli.exe\" -p Helpdesk2.mpr -c \"SHOW DEMO USERS\")",
      "Bash(\"./mxcli.exe\" -p Helpdesk2.mpr -c \"DESCRIBE USER ROLE Administrator\")",
      "Bash(\"./mxcli.exe\" -p Helpdesk2.mpr -c \"DESCRIBE USER ROLE User\")",
      "Bash(\"./mxcli.exe\" -p Helpdesk2.mpr -c \"SHOW SECURITY MATRIX\")",
      "Bash(git init *)",
      "Bash(git add *)"
    ],
    "deny": [
      "Bash(rm -rf)"
    ]
  }
}
