{
  "env": {
    "MXCLI_QUIET": "1"
  },
  "permissions": {
    "allow": [
      "Bash(./mxcli:*)",
      "Bash(./mxcli *)",
      "Bash(./mxcli.exe)",
      "Bash(* ./mxcli.exe *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(grep -r*)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(playwright-cli:*)",
      "Bash(playwright-cli *)",
      "Bash(./mxcli.exe exec *)",
      "Bash(docker compose *)",
      "Bash(docker exec *)",
      "Bash(docker ps)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(bash tests/*.sh)",
      "Bash(/c/Users/z004jcbp/AppData/Roaming/npm/playwright-cli *)",
      "Bash(\"C:/Program Files/Mendix/11.6.6/modeler/mx\" check *)",
      "Bash(node -e \"const pw = require\\('@playwright/cli/node_modules/playwright-core'\\); console.log\\(pw.chromium ? 'has chromium' : 'no'\\);\")",
      "Read(//c/Users/z004jcbp/AppData/Roaming/npm/node_modules/@playwright/cli/node_modules/.bin//**)",
      "Bash(npx playwright *)",
      "Bash(curl -s http://localhost:9323)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:9323)",
      "Bash(find \"C:/dev/MxCLI/Macnica-POC-share\" -type f | sort 2>&1)",
      "Read(//c/dev/MxCLI/Macnica-POC-share/**)",
      "Bash(find \"C:/Users/z004jcbp/.claude/projects/c--dev-MxCLI-PayerBilling-PayerBilling5/memory\" -type f | sort 2>&1)",
      "Read(//c/Users/z004jcbp/.claude/projects/c--dev-MxCLI-PayerBilling-PayerBilling5/memory/**)"
    ],
    "deny": [
      "Bash(rm -rf)",
      "Bash(./mxcli docker down*)",
      "Bash(mxcli docker down*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "cd 'c:/dev/MxCLI/Handson/Helpdesk2/.docker' && docker compose down 2>/dev/null || true",
            "statusMessage": "Stopping Docker before push..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(./mxcli exec mdl-examples/helpdesk-app.mdl *)",
            "command": "cd 'c:/dev/MxCLI/Handson/Helpdesk2' && cp -r mprcontents/. .mendix-cache/base_data/mprcontents/ && cp Helpdesk2.mpr .mendix-cache/base_data/Helpdesk2.mpr 2>/dev/null || true",
            "statusMessage": "Syncing mprcontents to .mendix-cache..."
          }
        ]
      }
    ]
  }
}
